# Video Subtitles Automation - Environment Variables

# OpenAI API Key (required for Whisper and GPT)
OPENAI_API_KEY=your-openai-api-key-here

# Application Settings
DEBUG=True
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# File Upload Settings
MAX_VIDEO_SIZE_MB=500
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
CLEANUP_MAX_AGE_HOURS=24
CLEANUP_INTERVAL_HOURS=24

# Queue / Redis (rq worker must use the same URL — run: python scripts/rq_worker.py)
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=video_jobs
QUEUE_JOB_TIMEOUT_SECONDS=21600

# Default Language Settings
DEFAULT_FONT=Arial
DEFAULT_SUBTITLE_POSITION=bottom
